PORT=4000
# Logs: 1=cores no terminal/docker, 0=plain text
AI_FACTORY_LOG_COLOR=1
AI_FACTORY_LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aifactory
JWT_SECRET=change-me-in-production
MASTER_PASSWORD=change-me
WORKER_SECRET=change-me-worker
ENCRYPTION_KEY=32-char-minimum-secret-key-here!!
ALLOW_DEV_ROUTES=true
# URL do front em dev interno (Vite)
CORS_ORIGIN=http://localhost:5173
BILLING_CB_ESTIMATE_USD=0.50
# Meta de custo do projeto: scope preview × microCount × fator (PO + tasks + dev por micro). Default 4
PROJECT_COST_MICRO_PIPELINE_FACTOR=4
# Prévia de tokens (campo Cursor ÷ 100). Alinhado ao CLI billing-preview
CURSOR_PREVIEW_CHARGE_FIELD_PER_MILLION=0.8
# Deploy Railway: API (railway.json) + serviço separado em ai-factory-poller.
# Ver docs/DEPLOY-RAILWAY.md e ai-factory-poller/.env.example
# Dev local — poller noutro terminal: cd ai-factory-poller && npm run dev
# Match/settle (poller): distância máxima |timestamp Cursor − ended_at| (ms). Default 120000 (2 min)
BILLING_MAX_MATCH_DELTA_MS=120000
# Busca na API Cursor: margem antes do início / depois do fim do job (ms)
CURSOR_USAGE_START_BUFFER_MS=120000
CURSOR_USAGE_END_BUFFER_MS=60000
PLATFORM_ADMIN_EMAILS=daniel.espindola.l@hotmail.com
# Caminho para data/tenants do repo CLI (irmão)
TENANT_DATA_DIR=../ai-factory-cli/data/tenants
# Redis no host (API back em npm run dev)
REDIS_URL=redis://127.0.0.1:6379
# Redis no .env do worker Docker (pull-tenant-env); não usar 127.0.0.1 no container
TENANT_REDIS_URL=redis://host.docker.internal:6379
# Alternativa com redis-stack na rede N8N: redis://redis-stack:6379
JOB_LOG_TTL_SECONDS=604800

# Stripe (webhook + Payment Links)
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SECRET_KEY=sk_test_...
# Admin API Cursor aplicada a novos tenants no webhook (se tenant ainda não tiver override)
PLATFORM_CURSOR_ADMIN_API_KEY=
# Opcional: mapear Price ID → plano se metadata plan_id não vier no Payment Link
STRIPE_PRICE_STARTER=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_BUSINESS=
# Apenas desenvolvimento local (senha fixa do auditor). Em produção deixe vazio para senha aleatória.
STRIPE_DEFAULT_USER_PASSWORD=

# URL pública do back (GitHub OAuth, Stripe, links externos)
PUBLIC_BACK_URL=https://your-back.railway.app
# URL interna para workers CLI no Railway (mesmo project/env que a API):
# WORKER_BACK_URL=http://${{ai-factory-back.RAILWAY_PRIVATE_DOMAIN}}:${{ai-factory-back.PORT}}
# Redis interno para workers (opcional; senão usa TENANT_REDIS_URL / REDIS_URL):
# WORKER_REDIS_URL=${{Redis.REDIS_URL}}  # preferir URL privada do plugin Redis

# Provisionamento automático CLI no Railway (Modelo A: 1 serviço por tenant)
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT_ID=
RAILWAY_CLI_TEMPLATE_SERVICE_ID=
# Publicação de projectos concluídos (repo deploy privado → Railway project por slug)
RAILWAY_WORKSPACE_ID=
RAILWAY_CLIENT_PROJECT_PREFIX=df
GITHUB_DEPLOY_REPO_PREFIX=df-deploy
# Opcional — defaults no código: cloudsystec/AI-ai-factory-cli, main
# RAILWAY_CLI_REPO=
# RAILWAY_CLI_BRANCH=
# Região: não enviamos no staging (default Railway). Só fallback em volumeCreate:
# RAILWAY_CLI_REGION=us-west1

# Build Docker incluído no provisionamento (config + deploy num fluxo)
# RAILWAY_WORKER_SKIP_BUILD=true  # só config, sem build (debug)
# Volume persistente criado no provisionamento (/app/data/tenants/<uuid>)
# RAILWAY_WORKER_SKIP_VOLUME=true  # desliga volumeCreate (só debug)
# Publicação projectos concluídos: ver docs/DEPLOY-RAILWAY-CLIENT.md

# GitHub App (https://github.com/apps/<slug>)
# Installation ID da org da plataforma (repos managed sem Git do cliente)
GITHUB_PLATFORM_INSTALLATION_ID=
# Prefixo dos repos managed: df-{tenant8}-{projectSlug}
GITHUB_MANAGED_REPO_PREFIX=df
# 1) Gere uma private key na app (GitHub → Developer settings → GitHub Apps → Private keys)
# 2) Guarde o .pem em ai-factory-back/github-app-private-key.pem (não commitar)
#    OU cole o PEM em GITHUB_APP_PRIVATE_KEY (uma linha com \n entre linhas)
GITHUB_APP_ID=3797242
GITHUB_APP_CLIENT_ID=Iv23li37JucJf0fD9Osg
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=./github-app-private-key.pem
GITHUB_APP_SLUG=cloudsys-tec
# Retry auth GitHub App (401/429 intermitente). Default: 4 tentativas, pausas 500,1000,2000,4000 ms
# GITHUB_APP_RETRY_MAX_ATTEMPTS=4
# GITHUB_APP_RETRY_DELAY_MS=500,1000,2000,4000
# Na GitHub App → Callback URL (ou Setup URL): use um destes (ambos funcionam no back)
GITHUB_OAUTH_CALLBACK_URL=http://localhost:4000/api/github/callback
# Alternativa aceite: http://localhost:4000/api/auth/github/callback
GITHUB_TL_MERGE_METHOD=squash

# E-mail (Amazon SES API v2 ou Postmark)
# EMAIL_PROVIDER=ses | postmark | console | noop
EMAIL_PROVIDER=ses
EMAIL_FROM=noreply@seudominio.com
EMAIL_FROM_NAME=dev for less
EMAIL_REPLY_TO=suporte@seudominio.com
# URL pública do front (logo, links de login). Fallback: 1.º valor de CORS_ORIGIN
PUBLIC_FRONT_URL=https://app.seudominio.com

# --- Amazon SES (quando EMAIL_PROVIDER=ses) ---
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Opcional
AWS_SES_CONFIGURATION_SET=

# --- Postmark (quando EMAIL_PROVIDER=postmark) ---
POSTMARK_SERVER_TOKEN=
# Opcional: stream transacional (default outbound)
# POSTMARK_MESSAGE_STREAM=outbound
# POSTMARK_API_URL=https://api.postmarkapp.com/email
